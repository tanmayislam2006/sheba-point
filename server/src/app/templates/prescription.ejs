<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Prescription Ready</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 20px 10px;
      background-color: #eef4fb;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #1e293b;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      border="0"
      style="max-width: 680px; margin: 0 auto"
    >
      <tr>
        <td>
          <table
            role="presentation"
            width="100%"
            cellspacing="0"
            cellpadding="0"
            border="0"
            style="
              border-radius: 18px;
              overflow: hidden;
              background: #ffffff;
              box-shadow: 0 18px 48px rgba(2, 8, 23, 0.12);
            "
          >
            <tr>
              <td
                style="
                  background: linear-gradient(125deg, #0b3c5d 0%, #156a96 55%, #2aa6d6 100%);
                  color: #ffffff;
                  padding: 30px 26px 26px;
                "
              >
                <p style="margin: 0; font-size: 13px; opacity: 0.92">
                  Sheba Point Prescription Center
                </p>
                <h1
                  style="
                    margin: 10px 0 0;
                    font-size: 28px;
                    line-height: 1.2;
                    letter-spacing: 0.3px;
                  "
                >
                  Your Prescription Is Ready
                </h1>
              </td>
            </tr>

            <tr>
              <td style="padding: 26px 24px 14px">
                <p style="margin: 0 0 10px; font-size: 16px">
                  Hello <strong><%= patientName %></strong>,
                </p>
                <p style="margin: 0; color: #475569; font-size: 15px; line-height: 1.75">
                  Dr. <strong><%= doctorName %></strong> has issued your prescription.
                  You can review the key details below and download the attached PDF.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 6px 24px 8px">
                <table
                  role="presentation"
                  width="100%"
                  cellspacing="0"
                  cellpadding="0"
                  border="0"
                  style="
                    border: 1px solid #dbe7f3;
                    border-radius: 14px;
                    overflow: hidden;
                    background: #f8fbff;
                  "
                >
                  <tr>
                    <td style="padding: 16px 16px 14px">
                      <table
                        role="presentation"
                        width="100%"
                        cellspacing="0"
                        cellpadding="0"
                        border="0"
                      >
                        <tr>
                          <td style="width: 50%; vertical-align: top; padding-right: 8px">
                            <p style="margin: 0; font-size: 12px; color: #64748b">Prescription ID</p>
                            <p style="margin: 6px 0 0; font-size: 14px; font-weight: 700"><%= prescriptionId %></p>
                          </td>
                          <td style="width: 50%; vertical-align: top; padding-left: 8px">
                            <p style="margin: 0; font-size: 12px; color: #64748b">Specialization</p>
                            <p style="margin: 6px 0 0; font-size: 14px; font-weight: 700">
                              <%= specialization || "General Medicine" %>
                            </p>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding-top: 14px; vertical-align: top; padding-right: 8px">
                            <p style="margin: 0; font-size: 12px; color: #64748b">Appointment</p>
                            <p style="margin: 6px 0 0; font-size: 14px; font-weight: 700"><%= appointmentDate %></p>
                          </td>
                          <td style="padding-top: 14px; vertical-align: top; padding-left: 8px">
                            <p style="margin: 0; font-size: 12px; color: #64748b">Follow-up Date</p>
                            <p style="margin: 6px 0 0; font-size: 14px; font-weight: 700"><%= followUpDate %></p>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding-top: 14px; vertical-align: top; padding-right: 8px">
                            <p style="margin: 0; font-size: 12px; color: #64748b">Issued On</p>
                            <p style="margin: 6px 0 0; font-size: 14px; font-weight: 700"><%= issuedDate %></p>
                          </td>
                          <td style="padding-top: 14px; vertical-align: top; padding-left: 8px">
                            <p style="margin: 0; font-size: 12px; color: #64748b">Doctor</p>
                            <p style="margin: 6px 0 0; font-size: 14px; font-weight: 700">
                              Dr. <%= doctorName %>
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding: 14px 24px 10px">
                <p
                  style="
                    margin: 0 0 10px;
                    font-size: 13px;
                    text-transform: uppercase;
                    letter-spacing: 1.1px;
                    color: #0b3c5d;
                    font-weight: 700;
                  "
                >
                  Instructions
                </p>
                <div
                  style="
                    border-left: 4px solid #2aa6d6;
                    background: #f8fbff;
                    border-radius: 10px;
                    padding: 14px 14px 14px 16px;
                    color: #334155;
                    font-size: 14px;
                    line-height: 1.7;
                  "
                >
                  <%= instructions %>
                </div>
              </td>
            </tr>

            <tr>
              <td style="padding: 18px 24px 26px">
                <a
                  href="<%= pdfUrl %>"
                  style="
                    display: inline-block;
                    background: #0b3c5d;
                    color: #ffffff;
                    text-decoration: none;
                    border-radius: 10px;
                    padding: 12px 18px;
                    font-size: 14px;
                    font-weight: 700;
                  "
                >
                  View Prescription PDF
                </a>
              </td>
            </tr>

            <tr>
              <td
                style="
                  border-top: 1px solid #e2e8f0;
                  padding: 18px 24px 24px;
                  font-size: 12px;
                  line-height: 1.7;
                  color: #64748b;
                "
              >
                <p style="margin: 0">
                  This is an electronically generated medical prescription.
                  Please follow your doctor's guidance and do not self-adjust dosage.
                </p>
                <p style="margin: 6px 0 0">Sheba Point Health Platform</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
