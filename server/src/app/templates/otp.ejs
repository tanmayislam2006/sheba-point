<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>OTP Verification</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 24px 12px;
      background: #f3f6fb;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2937;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      border="0"
      style="max-width: 620px; margin: 0 auto"
    >
      <tr>
        <td style="padding: 0">
          <table
            role="presentation"
            width="100%"
            cellspacing="0"
            cellpadding="0"
            border="0"
            style="
              background: #ffffff;
              border-radius: 14px;
              overflow: hidden;
              box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
            "
          >
            <tr>
              <td
                style="
                  background: linear-gradient(135deg, #0f766e, #0891b2);
                  color: #ffffff;
                  padding: 26px 24px;
                "
              >
                <h1
                  style="
                    margin: 0;
                    font-size: 22px;
                    font-weight: 700;
                    line-height: 1.2;
                  "
                >
              Sheba Point
                </h1>
                <p
                  style="
                    margin: 8px 0 0;
                    font-size: 14px;
                    opacity: 0.95;
                    line-height: 1.5;
                  "
                >
                  OTP Verification
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 28px 24px 18px">
                <p style="margin: 0 0 12px; font-size: 16px">
                  Hi <strong><%= typeof name !== "undefined" && name ? name : "User" %></strong>,
                </p>
                <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #4b5563">
                  Use the code below to complete your verification. This code is valid for
                  <strong><%= typeof expiresIn !== "undefined" && expiresIn ? expiresIn : "2 minutes" %></strong>.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 8px 24px 10px">
                <div
                  style="
                    background: #ecfeff;
                    border: 1px solid #99f6e4;
                    border-radius: 12px;
                    text-align: center;
                    padding: 20px 12px;
                  "
                >
                  <div
                    style="
                      font-size: 32px;
                      font-weight: 800;
                      letter-spacing: 10px;
                      color: #0f766e;
                    "
                  >
                    <%= otp %>
                  </div>
                </div>
              </td>
            </tr>

            <tr>
              <td style="padding: 12px 24px 20px">
                <p style="margin: 0; font-size: 13px; line-height: 1.7; color: #6b7280">
                  For your security, do not share this code with anyone.
                  If you did not request this OTP, please ignore this email.
                </p>
              </td>
            </tr>

            <tr>
              <td
                style="
                  padding: 16px 24px 24px;
                  border-top: 1px solid #e5e7eb;
                  font-size: 12px;
                  line-height: 1.7;
                  color: #9ca3af;
                "
              >
                <p style="margin: 0">
                  Need help?
                  <a
                    href="mailto:<%= typeof supportEmail !== 'undefined' && supportEmail ? supportEmail : 'support@shebapoint.com' %>"
                    style="color: #0891b2; text-decoration: none"
                  >
                    <%= typeof supportEmail !== "undefined" && supportEmail ? supportEmail : "support@shebapoint.com" %>
                  </a>
                </p>
                <p style="margin: 6px 0 0">
                  <%= typeof appName !== "undefined" && appName ? appName : "Sheba Point" %>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
